# ──────────────────────────────────────────────────────
# meuip.me — environment variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────

# Site base URL (used for canonical, OG, sitemap)
NUXT_PUBLIC_SITE_URL=https://meuip.me

# ── Analytics (leave empty to disable tracking) ──────

# Google Analytics 4 Measurement ID
# Get it from: https://analytics.google.com → Admin → Data Streams
NUXT_PUBLIC_GA_ID=

# Google Tag Manager Container ID (alternative to GA direct)
# Only used when NUXT_PUBLIC_GA_ID is empty
NUXT_PUBLIC_GTM_ID=

# Bing Webmaster Tools site verification code
# Get it from: https://www.bing.com/webmasters → Add Site → Meta tag value
NUXT_PUBLIC_BING_ID=
